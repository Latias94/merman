{
  "name": "merman-vscode",
  "displayName": "Merman",
  "description": "Local Mermaid authoring, diagnostics, preview, and export powered by Merman.",
  "version": "0.8.0-alpha.2",
  "publisher": "latias94",
  "preview": true,
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/Latias94/merman#readme",
  "bugs": {
    "url": "https://github.com/Latias94/merman/issues"
  },
  "qna": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Latias94/merman.git"
  },
  "engines": {
    "vscode": "^1.121.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "mermaid",
    "diagram",
    "preview",
    "lsp",
    "diagnostics",
    "export",
    "markdown",
    "mdx"
  ],
  "galleryBanner": {
    "color": "#0B3D3A",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:mermaid",
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onCommand:merman.restartLanguageServer",
    "onCommand:merman.openPreview",
    "onCommand:merman.togglePreviewLock",
    "onCommand:merman.refreshPreview",
    "onCommand:merman.showPreviewSource",
    "onCommand:merman.export",
    "onCommand:merman.exportSvg",
    "onCommand:merman.exportPng",
    "onCommand:merman.copySvg",
    "onCommand:merman.copyPng",
    "onCommand:merman.showRuleCatalog",
    "onCommand:merman.showConfigSchema",
    "workspaceContains:**/*.mmd",
    "workspaceContains:**/*.mermaid"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid",
          "mermaid"
        ],
        "extensions": [
          ".mmd",
          ".mermaid"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "mermaid",
        "path": "./snippets/mermaid.json"
      }
    ],
    "configuration": {
      "title": "Merman",
      "properties": {
        "merman.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional absolute path to a prebuilt `merman-lsp` executable. Leave empty to use the packaged binary. Paths inside the current workspace require workspace trust."
        },
        "merman.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional arguments appended when launching `merman-lsp` directly."
        },
        "merman.server.useCargoRun": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Development only: launch `merman-lsp` through `cargo run -p merman-lsp --` instead of the packaged binary. Requires workspace trust."
        },
        "merman.server.cargoArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Development only: extra Cargo arguments inserted before `--` when launching `merman-lsp` through Cargo."
        },
        "merman.cli.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional absolute path to a prebuilt `merman-cli` executable used for local preview and export. Leave empty to use the packaged binary. Paths inside the current workspace require workspace trust."
        },
        "merman.cli.useCargoRun": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Development only: launch `merman-cli` through `cargo run -p merman-cli --` instead of the packaged binary. Requires workspace trust."
        },
        "merman.cli.cargoArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Development only: extra Cargo arguments inserted before `--` when launching `merman-cli` through Cargo."
        },
        "merman.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "markdownDescription": "LSP trace level forwarded to the VS Code language client."
        },
        "merman.languageIntelligence.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Start the local `merman-lsp` language server for completion, hover, symbols, references, rename, semantic tokens, diagnostics, and quick fixes. Disable this when using the extension only for preview and export."
        },
        "merman.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Publish Merman diagnostics to VS Code Problems. Disable this when another Mermaid or Markdown linter owns diagnostics; Merman completion, hover, symbols, references, rename, semantic tokens, preview, and export remain available."
        },
        "merman.sourceActions.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show Merman source-scoped CodeLens actions above `.mmd` files and Markdown/MDX Mermaid fences. Disable this when another preview/export extension owns those editor actions."
        },
        "merman.analysis.fixed_today": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional deterministic local date forwarded to `merman-lsp` analysis options in `YYYY-MM-DD` format."
        },
        "merman.analysis.fixed_local_offset_minutes": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "markdownDescription": "Optional deterministic local UTC offset in minutes forwarded to `merman-lsp` analysis options."
        },
        "merman.analysis.parse.suppress_errors": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Forward lenient parse mode to `merman-lsp`."
        },
        "merman.analysis.resources.max_source_bytes": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Optional source size cap forwarded to `merman-lsp`. `0` means unset."
        },
        "merman.analysis.lint.profile": {
          "type": "string",
          "enum": [
            "",
            "core",
            "recommended",
            "strict"
          ],
          "default": "recommended",
          "markdownDescription": "Lint profile forwarded to `merman-lsp`."
        },
        "merman.analysis.lint.enable_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional lint rules enabled in `merman-lsp`."
        },
        "merman.analysis.lint.disable_rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Lint rules disabled in `merman-lsp`."
        },
        "merman.analysis.lint.rule_severities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rule_id",
              "severity"
            ],
            "properties": {
              "rule_id": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "error",
                  "warning",
                  "info",
                  "hint"
                ]
              }
            }
          },
          "default": [],
          "markdownDescription": "Per-rule severity overrides forwarded to `merman-lsp`."
        }
      }
    },
    "commands": [
      {
        "command": "merman.restartLanguageServer",
        "title": "Merman: Restart Language Server"
      },
      {
        "command": "merman.openPreview",
        "title": "Merman: Open Preview",
        "category": "Merman",
        "icon": "$(open-preview)"
      },
      {
        "command": "merman.togglePreviewLock",
        "title": "Merman: Toggle Preview Lock",
        "category": "Merman",
        "icon": "$(lock)"
      },
      {
        "command": "merman.refreshPreview",
        "title": "Merman: Refresh Preview",
        "category": "Merman",
        "icon": "$(refresh)"
      },
      {
        "command": "merman.showPreviewSource",
        "title": "Merman: Show Preview Source",
        "category": "Merman",
        "icon": "$(go-to-file)"
      },
      {
        "command": "merman.export",
        "title": "Merman: Export...",
        "category": "Merman",
        "icon": "$(export)"
      },
      {
        "command": "merman.exportSvg",
        "title": "Merman: Export SVG",
        "category": "Merman",
        "icon": "$(export)"
      },
      {
        "command": "merman.exportPng",
        "title": "Merman: Export PNG",
        "category": "Merman",
        "icon": "$(file-media)"
      },
      {
        "command": "merman.copySvg",
        "title": "Merman: Copy SVG",
        "category": "Merman",
        "icon": "$(copy)"
      },
      {
        "command": "merman.copyPng",
        "title": "Merman: Copy PNG",
        "category": "Merman",
        "icon": "$(file-media)"
      },
      {
        "command": "merman.showRuleCatalog",
        "title": "Merman: Show Rule Catalog",
        "category": "Merman"
      },
      {
        "command": "merman.showConfigSchema",
        "title": "Merman: Show Config Schema",
        "category": "Merman"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "merman.openPreview",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@10"
        },
        {
          "command": "merman.export",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@11"
        },
        {
          "command": "merman.exportSvg",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@12"
        }
      ],
      "editor/context": [
        {
          "command": "merman.openPreview",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@10"
        },
        {
          "command": "merman.export",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@11"
        },
        {
          "command": "merman.exportSvg",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@12"
        },
        {
          "command": "merman.exportPng",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@13"
        },
        {
          "command": "merman.copySvg",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@14"
        },
        {
          "command": "merman.copyPng",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx",
          "group": "navigation@15"
        }
      ],
      "explorer/context": [
        {
          "command": "merman.openPreview",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@10"
        },
        {
          "command": "merman.export",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@11"
        },
        {
          "command": "merman.exportSvg",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@12"
        },
        {
          "command": "merman.exportPng",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid || resourceExtname == .md || resourceExtname == .markdown || resourceExtname == .mdx",
          "group": "navigation@13"
        }
      ],
      "commandPalette": [
        {
          "command": "merman.openPreview",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        },
        {
          "command": "merman.refreshPreview"
        },
        {
          "command": "merman.showPreviewSource"
        },
        {
          "command": "merman.export",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        },
        {
          "command": "merman.exportSvg",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        },
        {
          "command": "merman.exportPng",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        },
        {
          "command": "merman.copySvg",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        },
        {
          "command": "merman.copyPng",
          "when": "resourceLangId == mermaid || resourceLangId == markdown || resourceLangId == mdx"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run compile && npm run bundle",
    "compile": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node22 --external:vscode --outfile=dist/extension.js --sourcemap --sources-content=false",
    "check": "tsc -p . --noEmit",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "prepare:binaries": "node scripts/prepare-binaries.mjs",
    "package": "npm run build && vsce package",
    "verify:vsix": "node scripts/verify-vsix.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "10.0.1"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/vscode": "1.120.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "typescript": "6.0.3"
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "esbuild@0.28.1": true,
    "keytar@7.9.0": true
  }
}
