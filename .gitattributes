# Keep text files stable across platforms (especially Windows vs. CI Linux).
* text=auto

.gitattributes text eol=lf
.gitignore     text eol=lf
LICENSE        text eol=lf
LICENSE-*      text eol=lf

# Core sources/docs/fixtures
*.rs      text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.svg     text eol=lf
*.svgfrag text eol=lf
*.xml     text eol=lf
*.mmd     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.py      text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.kts     text eol=lf
*.gradle  text eol=lf
*.swift   text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.sh      text eol=lf
*.mjs     text eol=lf
*.lock    text eol=lf

# ASCII/Unicode golden fixtures intentionally preserve trailing character cells.
crates/merman-ascii/tests/testdata/mermaid-ascii/**/*.txt text eol=lf whitespace=-blank-at-eol

# Script formats
*.ps1 text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
