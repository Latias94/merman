{
  "name": "@mermanjs/web",
  "version": "0.8.0-alpha.1",
  "description": "Merman browser integration: WebAssembly renderer and TypeScript helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latias94/merman.git"
  },
  "homepage": "https://github.com/Latias94/merman/tree/main/platforms/web#readme",
  "keywords": [
    "mermaid",
    "diagram",
    "wasm",
    "svg",
    "renderer"
  ],
  "license": "MIT OR Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pkg/merman_wasm.js": {
      "import": "./pkg/merman_wasm.js",
      "types": "./pkg/merman_wasm.d.ts"
    },
    "./pkg/merman_wasm_bg.wasm": "./pkg/merman_wasm_bg.wasm"
  },
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:wasm": "wasm-pack build ../../crates/merman-wasm --target web --release --out-dir ../../platforms/web/pkg && node scripts/clean-pkg.mjs",
    "smoke": "node scripts/smoke.mjs",
    "prepack": "node scripts/prepack-check.mjs",
    "prepublishOnly": "npm run build && npm run smoke"
  },
  "files": [
    "LICENSE",
    "dist",
    "pkg",
    "src",
    "README.md"
  ],
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
