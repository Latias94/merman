{
  "name": "@mermanjs/web",
  "version": "0.8.0-alpha.2",
  "description": "Merman browser integration: WebAssembly renderer and TypeScript helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Latias94/merman.git"
  },
  "homepage": "https://github.com/Latias94/merman/tree/main/platforms/web#readme",
  "keywords": [
    "mermaid",
    "diagram",
    "wasm",
    "svg",
    "renderer"
  ],
  "license": "MIT OR Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/surfaces/core.js",
      "types": "./dist/surfaces/core.d.ts"
    },
    "./render": {
      "import": "./dist/surfaces/render.js",
      "types": "./dist/surfaces/render.d.ts"
    },
    "./ascii": {
      "import": "./dist/surfaces/ascii.js",
      "types": "./dist/surfaces/ascii.d.ts"
    },
    "./full": {
      "import": "./dist/surfaces/full.js",
      "types": "./dist/surfaces/full.d.ts"
    },
    "./pkg/merman_wasm.js": {
      "import": "./pkg/merman_wasm.js",
      "types": "./pkg/merman_wasm.d.ts"
    },
    "./pkg/merman_wasm_bg.wasm": "./pkg/merman_wasm_bg.wasm",
    "./pkg/core/merman_wasm.js": {
      "import": "./pkg/core/merman_wasm.js",
      "types": "./pkg/core/merman_wasm.d.ts"
    },
    "./pkg/core/merman_wasm_bg.wasm": "./pkg/core/merman_wasm_bg.wasm",
    "./pkg/render/merman_wasm.js": {
      "import": "./pkg/render/merman_wasm.js",
      "types": "./pkg/render/merman_wasm.d.ts"
    },
    "./pkg/render/merman_wasm_bg.wasm": "./pkg/render/merman_wasm_bg.wasm",
    "./pkg/ascii/merman_wasm.js": {
      "import": "./pkg/ascii/merman_wasm.js",
      "types": "./pkg/ascii/merman_wasm.d.ts"
    },
    "./pkg/ascii/merman_wasm_bg.wasm": "./pkg/ascii/merman_wasm_bg.wasm",
    "./pkg/full/merman_wasm.js": {
      "import": "./pkg/full/merman_wasm.js",
      "types": "./pkg/full/merman_wasm.d.ts"
    },
    "./pkg/full/merman_wasm_bg.wasm": "./pkg/full/merman_wasm_bg.wasm"
  },
  "scripts": {
    "build": "npm run build:wasm && npm run build:surfaces && npm run build:ts",
    "build:ts": "npm run check:contracts && tsc -p tsconfig.build.json",
    "build:wasm": "node scripts/build-wasm.mjs",
    "build:surfaces": "node scripts/build-surface-packages.mjs",
    "build:wasm:core": "node scripts/build-wasm.mjs --preset browser-core",
    "build:wasm:render": "node scripts/build-wasm.mjs --preset browser-render",
    "build:wasm:ascii": "node scripts/build-wasm.mjs --preset browser-ascii",
    "build:wasm:full": "node scripts/build-wasm.mjs --preset browser-full",
    "build:wasm:ratex-math": "node scripts/build-wasm.mjs --preset browser-ratex-math",
    "check:contracts": "node scripts/check-contracts.mjs",
    "smoke:dom-safety": "node scripts/dom-safety-smoke.mjs",
    "smoke": "node scripts/smoke.mjs && npm run smoke:dom-safety",
    "prepack": "npm run check:contracts && node scripts/prepack-check.mjs",
    "prepublishOnly": "npm run build && npm run smoke"
  },
  "files": [
    "LICENSE",
    "dist",
    "pkg",
    "src",
    "README.md"
  ],
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
